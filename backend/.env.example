# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/jobPortalDB

# Server port
PORT=8000

# JWT Secret — use a long random string (minimum 64 chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=your_super_secret_jwt_key_replace_this_with_a_long_random_string

# Cloudinary credentials — get from https://cloudinary.com/console
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret
